# ─── Database ────────────────────────────────────────────────
DB_NAME=blackbox_db
DB_USER=blackbox
DB_PASSWORD=change_me_in_production

# ─── Spring Boot DB 연결 ──────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/blackbox_db
SPRING_DATASOURCE_USERNAME=blackbox
SPRING_DATASOURCE_PASSWORD=change_me_in_production

# ─── JWT ─────────────────────────────────────────────────────
# 최소 32자 이상의 랜덤 문자열
JWT_SECRET=change_me_a_long_random_string_at_least_32_chars

# ─── CORS ─────────────────────────────────────────────────────
# 로컬: 비워두면 application-local.yml 기본값 * 적용
# 배포: 실제 도메인 입력 (예: https://teamblackbox.com)
APP_CORS_ORIGINS=

# ─── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080

# ─── 확장 1: GitHub App ────────────────────────────────────────
# 비워두면 해당 기능 비활성화
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# ─── 확장 2: Google OAuth / Calendar API ──────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── AI API (둘 중 하나만 있어도 됨, Claude 우선) ─────────────
CLAUDE_API_KEY=
OPENAI_API_KEY=

# ─── Notion 연동 ──────────────────────────────────────────────
# Notion Integration Token (https://www.notion.so/my-integrations)
NOTION_API_KEY=
# 회의록을 내보낼 Notion 상위 페이지 ID (URL 마지막 32자리)
NOTION_PARENT_PAGE_ID=
# 회의 캘린더 동기화용 Notion DB ID (선택)
NOTION_CALENDAR_DB_ID=

# ─── Discord 알림 ─────────────────────────────────────────────
# Discord 채널 → 설정 → 연동 → 웹후크 → 웹후크 URL 복사
DISCORD_WEBHOOK_URL=
