# ─── Database ────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/blackbox_db
SPRING_DATASOURCE_USERNAME=blackbox
SPRING_DATASOURCE_PASSWORD=change_me_in_production

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET=change_me_a_long_random_string_at_least_32_chars
JWT_EXPIRATION_MS=1800000
JWT_REFRESH_EXPIRATION_MS=604800000

# ─── CORS ─────────────────────────────────────────────────────
# 로컬: 비워두면 * (모든 origin 허용)
# 배포: https://teamblackbox.com
APP_CORS_ORIGINS=

# ─── Google OAuth / Calendar API ──────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost/api/auth/google/callback

# ─── GitHub App ───────────────────────────────────────────────
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# ─── AI API (Claude 우선, 없으면 OpenAI 사용) ─────────────────
CLAUDE_API_KEY=
OPENAI_API_KEY=

# ─── Notion 연동 ──────────────────────────────────────────────
NOTION_API_KEY=
NOTION_PARENT_PAGE_ID=
NOTION_CALENDAR_DB_ID=

# ─── Discord 알림 ─────────────────────────────────────────────
# Discord 채널 → 설정 → 연동 → 웹후크 → 웹후크 URL 복사
DISCORD_WEBHOOK_URL=
